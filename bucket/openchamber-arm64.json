{
  "version": "1.16.3",
  "description": "Unofficial Windows ARM64 build of OpenChamber.",
  "homepage": "https://github.com/airtaxi/openchamber-windows-arm64",
  "license": "MIT",
  "depends": "7zip",
  "architecture": {
    "arm64": {
      "url": "https://github.com/airtaxi/openchamber-windows-arm64/releases/download/v1.16.3/dist.7z",
      "hash": "bc2571ce94c002f75b28a1cb6848cc9eb4f5411c05b364d5a8e7ad2712b92519"
    }
  },
  "installer": {
    "script": [
      "$exe = Get-ChildItem -LiteralPath $dir -Filter \"OpenChamber-*-win-arm64.exe\" | Select-Object -First 1",
      "if (-not $exe) { throw \"OpenChamber ARM64 installer not found.\" }",
      "Write-Host \"Installing OpenChamber ARM64...\"",
      "Start-Process -FilePath $exe.FullName -ArgumentList \"/S\" -Wait"
    ]
  },
  "notes": "This is an unofficial ARM64 build. OpenChamber is a desktop AI coding agent."
}
